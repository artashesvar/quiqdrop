# Copy this file to .env and fill in your values.
# Never commit the real .env file to git — it contains secret keys!

# Get this from BotFather on Telegram (@BotFather → /newbot)
TELEGRAM_BOT_TOKEN=

# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get this from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Get these from your Notion PUBLIC integration (notion.so/my-integrations)
# The integration must be set to "Public" (not Internal) to support OAuth.
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# The full public URL where Notion will redirect users after they authorise.
# Format: https://{your-railway-app-url}/notion/callback
# You must also add this exact URL to your Notion integration's "Redirect URIs" list.
# For local testing you can use a tunnel tool like ngrok: https://{ngrok-id}.ngrok.io/notion/callback
NOTION_REDIRECT_URI=https://your-railway-url/notion/callback
PORT=8080
